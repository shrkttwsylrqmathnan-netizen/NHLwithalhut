/* ════════════════════════════════════════════════════
   DESIGN 6 — REVOLUT / GLASSMORPHISM LIGHT
   ════════════════════════════════════════════════════ */
.d6 {
  background: linear-gradient(135deg, #FFF8E1 0%, #FFFDE7 30%, #f8f9fa 100%);
  min-height: 100vh;
  font-family: 'Cairo', sans-serif;
  position: relative;
  overflow: hidden;
}
.d6::before {
  content: '';
  position: absolute;
  width: 400px; height: 400px;
  background: radial-gradient(circle, rgba(255,193,7,0.25), transparent 70%);
  top: -100px; right: -100px; border-radius: 50%;
}
.d6::after {
  content: '';
  position: absolute;
  width: 300px; height: 300px;
  background: radial-gradient(circle, rgba(255,152,0,0.15), transparent 70%);
  bottom: 100px; left: -50px; border-radius: 50%;
}
.d6-body { padding: 50px 24px; position: relative; z-index: 1; }
.d6-logo-row { display: flex; align-items: center; gap: 12px; margin-bottom: 40px; }
.d6-logo-icon {
  width: 50px; height: 50px; border-radius: 18px;
  background: linear-gradient(135deg, #FFC107, #FF8F00);
  display: flex; align-items: center; justify-content: center; font-size: 1.5rem;
  box-shadow: 0 8px 24px rgba(255,193,7,0.35);
}
.d6-logo-text h3 { font-size: 1.2rem; font-weight: 900; color: #111; }
.d6-logo-text p { font-size: 0.72rem; color: #9ca3af; font-weight: 700; }
.d6-glass-card {
  background: rgba(255,255,255,0.7);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(255,193,7,0.25);
  border-radius: 28px; padding: 30px;
  box-shadow: 0 20px 60px rgba(255,193,7,0.12), 0 4px 20px rgba(0,0,0,0.06);
  margin-bottom: 20px;
}
.d6-input {
  width: 100%; border: 1.5px solid rgba(255,193,7,0.3);
  border-radius: 16px; padding: 14px 18px;
  font-family: 'Cairo', sans-serif; font-size: 1rem; font-weight: 700;
  color: #111; background: rgba(255,255,255,0.8);
  margin-bottom: 14px; outline: none; transition: 0.2s;
}
.d6-input:focus { border-color: #FFC107; background: rgba(255,253,231,0.9); }
.d6-btn {
  width: 100%; padding: 16px;
  background: linear-gradient(135deg, #FFC107, #FF8F00);
  color: #fff; border: none; border-radius: 16px;
  font-family: 'Cairo', sans-serif; font-size: 1.05rem; font-weight: 900;
  cursor: pointer; box-shadow: 0 10px 30px rgba(255,193,7,0.35);
  transition: 0.2s;
}
.d6-btn:hover { transform: translateY(-2px); }
.d6-earn-card {
  background: linear-gradient(135deg, #FF8F00, #FFC107);
  border-radius: 24px; padding: 28px 24px;
  position: relative; overflow: hidden;
}
.d6-earn-card::after { content: '🐝'; position: absolute; left: -10px; bottom: -20px; font-size: 8rem; opacity: 0.1; }
.d6-earn-lbl { font-size: 0.72rem; font-weight: 800; color: rgba(255,255,255,0.7); text-transform: uppercase; letter-spacing: 0.5px; }
.d6-earn-num { font-size: 2.8rem; font-weight: 900; color: #fff; letter-spacing: -1px; }
.d6-earn-unit { font-size: 1rem; color: rgba(255,255,255,0.7); }
/* dashboard */
.d1-dash { padding:0; }
.d1-dash-header { background:linear-gradient(180deg,#FFFDE7,#fff);padding:28px 24px 20px;border-bottom:1px solid #f0f0f0; }
.d1-dash-row { display:flex;justify-content:space-between;align-items:center;margin-bottom:16px; }
.d1-dash-name { font-size:1.1rem;font-weight:900;color:#111; }
.d1-dash-lvl { background:#FFF9C4;color:#F57F17;border:1px solid #FFE082;border-radius:99px;padding:3px 10px;font-size:0.6rem;font-weight:900; }
.d1-earn-lbl { font-size:0.65rem;font-weight:800;color:#9ca3af;text-transform:uppercase;letter-spacing:.5px;text-align:center;margin-bottom:4px; }
.d1-earn-num { font-size:2.6rem;font-weight:900;color:#FF8F00;text-align:center;letter-spacing:-1px; }
.d1-stats-row { display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-top:20px; }
.d1-stat { background:#fafafa;border:1px solid #f0f0f0;border-radius:18px;padding:14px 8px;text-align:center; }
.d1-stat-v { font-size:1.3rem;font-weight:900;color:#FFC107; }
.d1-stat-l { font-size:0.58rem;font-weight:800;color:#9ca3af;margin-top:3px; }
.d1-body { padding:20px 24px 30px; }

/* ════════════════════════════════════════════════════
   DESIGN 7 — CAREEM / PROFESSIONAL DARK ACCENT
   ════════════════════════════════════════════════════ */
.d7 {
  background: #fff;
  min-height: 100vh;
  font-family: 'Cairo', sans-serif;
}
.d7-header {
  background: #1C1B1F;
  padding: 50px 24px 60px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.d7-header::before {
  content: '';
  position: absolute; bottom: 0; left: 0; right: 0;
  height: 60px;
  background: #fff;
  border-radius: 40px 40px 0 0;
}
.d7-logo {
  width: 70px; height: 70px; border-radius: 24px;
  background: #FFC107;
  display: flex; align-items: center; justify-content: center;
  font-size: 2rem; margin: 0 auto 16px;
  box-shadow: 0 12px 40px rgba(255,193,7,0.4);
}
.d7-header h2 { font-size: 1.8rem; font-weight: 900; color: #fff; margin-bottom: 4px; }
.d7-header p { font-size: 0.8rem; color: rgba(255,255,255,0.5); font-weight: 700; }
.d7-body { padding: 10px 24px 40px; }
.d7-card {
  background: #fff; border-radius: 24px;
  border: 1px solid #f0f0f0;
  box-shadow: 0 8px 30px rgba(0,0,0,0.06);
  padding: 28px; margin-bottom: 16px;
}
.d7-section-title {
  font-size: 0.65rem; font-weight: 900; color: #9ca3af;
  text-transform: uppercase; letter-spacing: 1.5px;
  margin-bottom: 16px; display: flex; align-items: center; gap: 8px;
}
.d7-section-title::after { content: ''; flex: 1; height: 1px; background: #f0f0f0; }
.d7-input {
  width: 100%; border: 1.5px solid #f0f0f0;
  border-radius: 14px; padding: 14px 16px;
  font-family: 'Cairo', sans-serif; font-size: 1rem; font-weight: 700;
  color: #111; background: #fafafa; margin-bottom: 12px; outline: none; transition: 0.2s;
}
.d7-input:focus { border-color: #FFC107; background: #FFFDE7; }
.d7-btn {
  width: 100%; padding: 16px;
  background: #1C1B1F; color: #FFC107;
  border: none; border-radius: 14px;
  font-family: 'Cairo', sans-serif; font-size: 1.05rem; font-weight: 900;
  cursor: pointer; transition: 0.2s;
  position: relative; overflow: hidden;
}
.d7-btn::after { content: ''; position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(255,193,7,0.1), transparent); }
.d7-btn:hover { background: #FFC107; color: #111; }
.d7-stats { display: grid; grid-template-columns: repeat(3,1fr); gap: 10px; margin-top: 8px; }
.d7-stat {
  text-align: center; padding: 16px 8px;
  background: #fafafa; border-radius: 16px; border: 1px solid #f0f0f0;
}
.d7-stat-v { font-size: 1.4rem; font-weight: 900; color: #1C1B1F; }
.d7-stat-v.accent { color: #FFC107; }
.d7-stat-l { font-size: 0.58rem; font-weight: 800; color: #9ca3af; margin-top: 4px; }
/* radar */
.d1-radar { background:#FFFDE7;border:2px solid #FFE082;border-radius:24px;padding:28px;text-align:center;margin-bottom:16px;position:relative;overflow:hidden; }
.d1-radar-rings { width:110px;height:110px;margin:0 auto 16px;position:relative;display:flex;align-items:center;justify-content:center; }
.d1-ring { position:absolute;inset:0;border-radius:50%;border:2px solid #FFC107;animation:pulse-ring 2.5s ease-out infinite; }
.d1-ring:nth-child(2){animation-delay:.8s} .d1-ring:nth-child(3){animation-delay:1.6s}
.d1-core { width:70px;height:70px;border-radius:50%;background:#fff;border:2px solid #FFE082;display:flex;align-items:center;justify-content:center;font-size:1.8rem;position:relative;z-index:2;box-shadow:0 0 20px rgba(255,193,7,0.25);animation:glow 2s ease-in-out infinite; }
.d1-radar-title { font-size:.95rem;font-weight:900;color:#111;margin-bottom:4px; }
.d1-radar-desc { font-size:.75rem;color:#9ca3af;font-weight:700; }
.d1-toggle-row { display:flex;align-items:center;justify-content:center;gap:10px;margin-top:14px; }
.d1-toggle { position:relative;width:52px;height:28px; }
.d1-toggle input { opacity:0;width:0;height:0; }
.d1-slider { position:absolute;cursor:pointer;inset:0;background:#e5e7eb;border-radius:30px;transition:.4s; }
.d1-slider:before { content:'';position:absolute;width:22px;height:22px;left:3px;bottom:3px;background:#fff;border-radius:50%;transition:.4s;box-shadow:0 2px 6px rgba(0,0,0,.15); }
.d1-toggle input:checked+.d1-slider { background:linear-gradient(135deg,#FFC107,#FF8F00); }
.d1-toggle input:checked+.d1-slider:before { transform:translateX(24px); }
.d1-toggle-lbl { font-size:.8rem;font-weight:800;color:#374151; }

/* ════════════════════════════════════════════════════
   DESIGN 8 — DUOLINGO / PLAYFUL & BOLD
   ════════════════════════════════════════════════════ */
.d8 {
  background: #FFFDE7;
  min-height: 100vh;
  font-family: 'Cairo', sans-serif;
}
.d8-header { padding: 40px 24px 30px; text-align: center; }
.d8-bee-circle {
  width: 100px; height: 100px; border-radius: 50%;
  background: #FFC107;
  display: flex; align-items: center; justify-content: center;
  font-size: 3rem; margin: 0 auto 20px;
  box-shadow: 0 6px 0 #E65100, 0 12px 30px rgba(255,193,7,0.3);
  animation: bounce 2s ease-in-out infinite;
}
@keyframes bounce { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }
.d8-header h2 { font-size: 2.2rem; font-weight: 900; color: #111; }
.d8-header p { font-size: 0.85rem; color: #9ca3af; font-weight: 700; margin-top: 4px; }
.d8-card {
  background: #fff; border-radius: 24px;
  border: 2px solid #FFE082;
  box-shadow: 0 6px 0 #FFE082;
  padding: 28px; margin: 0 20px 20px;
}
.d8-input {
  width: 100%; border: 2px solid #FFE082;
  border-radius: 14px; padding: 14px 18px;
  font-family: 'Cairo', sans-serif; font-size: 1rem; font-weight: 700;
  color: #111; background: #FFFDE7; margin-bottom: 14px; outline: none; transition: 0.2s;
}
.d8-input:focus { border-color: #FFC107; background: #fff; }
.d8-btn {
  width: 100%; padding: 16px;
  background: #FFC107; color: #111;
  border: none; border-radius: 14px;
  font-family: 'Cairo', sans-serif; font-size: 1.1rem; font-weight: 900;
  cursor: pointer;
  box-shadow: 0 6px 0 #E65100;
  transition: 0.1s; position: relative; top: 0;
}
.d8-btn:hover { top: 3px; box-shadow: 0 3px 0 #E65100; }
.d8-progress { margin: 0 20px 20px; }
.d8-prog-label {
  display: flex; justify-content: space-between;
  font-size: 0.75rem; font-weight: 800; color: #6b7280;
  margin-bottom: 8px;
}
.d8-prog-bar {
  height: 16px; background: #fff; border-radius: 99px;
  border: 2px solid #FFE082; overflow: hidden;
}
.d8-prog-fill {
  height: 100%; width: 40%;
  background: linear-gradient(90deg, #FFC107, #FFD54F);
  border-radius: 99px;
}
.d8-stats { display: flex; gap: 10px; padding: 0 20px; }
.d8-stat {
  flex: 1; background: #fff; border: 2px solid #FFE082;
  border-radius: 16px; box-shadow: 0 4px 0 #FFE082;
  padding: 16px 10px; text-align: center;
}
.d8-stat-v { font-size: 1.4rem; font-weight: 900; color: #111; }
.d8-stat-v.yellow { color: #FFC107; }
.d8-stat-l { font-size: 0.6rem; font-weight: 800; color: #9ca3af; margin-top: 4px; }
/* new order alert */
.d1-alert { background:linear-gradient(135deg,#FFFDE7,#FFF9C4);border:2px solid #FFE082;border-radius:24px;padding:20px;margin-bottom:14px;animation:cardIn .4s; }
.d1-alert-top { display:flex;justify-content:space-between;align-items:center;margin-bottom:14px; }
.d1-alert-title { font-size:1.1rem;font-weight:900;color:#111;display:flex;align-items:center;gap:8px; }
.d1-countdown { width:52px;height:52px;background:#FFC107;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.3rem;font-weight:900;color:#111;box-shadow:0 4px 14px rgba(255,193,7,0.4);animation:glow 1.5s ease-in-out infinite; }
.d1-alert-row { display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid rgba(255,193,7,0.2);align-items:center; }
.d1-alert-row:last-of-type { border-bottom:none; }
.d1-albl { font-size:.68rem;font-weight:700;color:#9ca3af; }
.d1-aval { font-size:.95rem;font-weight:900;color:#111; }
.d1-aval.price { color:#FF8F00;font-size:1.2rem; }
.d1-accept { width:100%;padding:14px;background:linear-gradient(135deg,#22c55e,#16a34a);color:#fff;border:none;border-radius:14px;font-family:'Cairo',sans-serif;font-size:1rem;font-weight:900;cursor:pointer;margin-top:12px;box-shadow:0 6px 20px rgba(34,197,94,0.3); }

/* ════════════════════════════════════════════════════
   DESIGN 9 — LINEAR / TECH PRECISION
   ════════════════════════════════════════════════════ */
.d9 {
  background: #FAFAF9;
  min-height: 100vh;
  font-family: 'Cairo', sans-serif;
}
.d9-topbar {
  padding: 18px 24px;
  background: rgba(255,255,255,0.8);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid #e5e7eb;
  display: flex; align-items: center; justify-content: space-between;
  position: sticky; top: 0; z-index: 100;
}
.d9-logo { display: flex; align-items: center; gap: 10px; }
.d9-logo-mark {
  width: 36px; height: 36px; border-radius: 10px;
  background: #111; display: flex; align-items: center; justify-content: center;
  font-size: 1.1rem; box-shadow: 0 2px 8px rgba(0,0,0,0.15);
}
.d9-logo-name { font-size: 1rem; font-weight: 900; color: #111; }
.d9-badge {
  background: #FFFDE7; border: 1px solid #FFE082;
  color: #F57F17; font-size: 0.65rem; font-weight: 900;
  padding: 4px 10px; border-radius: 6px;
}
.d9-body { padding: 30px 24px; }
.d9-section { margin-bottom: 28px; }
.d9-section-header {
  font-size: 0.68rem; font-weight: 900; color: #9ca3af;
  text-transform: uppercase; letter-spacing: 1.5px;
  margin-bottom: 14px; padding-bottom: 10px;
  border-bottom: 1px solid #f0f0f0;
}
.d9-input {
  width: 100%; border: 1px solid #e5e7eb;
  border-radius: 10px; padding: 12px 14px;
  font-family: 'Cairo', sans-serif; font-size: 0.95rem; font-weight: 700;
  color: #111; background: #fff; margin-bottom: 10px; outline: none; transition: 0.2s;
}
.d9-input:focus { border-color: #FFC107; box-shadow: 0 0 0 3px rgba(255,193,7,0.1); }
.d9-btn {
  display: flex; align-items: center; justify-content: center; gap: 8px;
  width: 100%; padding: 13px;
  background: #111; color: #FFC107;
  border: none; border-radius: 10px;
  font-family: 'Cairo', sans-serif; font-size: 0.95rem; font-weight: 900;
  cursor: pointer; transition: 0.2s;
}
.d9-btn:hover { background: #FFC107; color: #111; }
.d9-metric-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.d9-metric {
  background: #fff; border: 1px solid #f0f0f0;
  border-radius: 14px; padding: 18px 16px;
  position: relative; overflow: hidden;
}
.d9-metric::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 2px;
  background: linear-gradient(90deg, #FFC107, #FFD54F);
}
.d9-metric-v { font-size: 1.5rem; font-weight: 900; color: #111; }
.d9-metric-l { font-size: 0.62rem; font-weight: 800; color: #9ca3af; margin-top: 4px; }
.d9-metric-trend { 
  position: absolute; top: 14px; left: 14px;
  font-size: 0.65rem; font-weight: 900; color: #10b981;
  background: rgba(16,185,129,0.08); padding: 2px 6px; border-radius: 4px;
}
/* active order card */
.d1-order { background:#fff;border:1.5px solid #FFE082;border-radius:20px;padding:18px;margin-bottom:12px;box-shadow:0 4px 16px rgba(255,193,7,0.1);position:relative;overflow:hidden; }
.d1-order::before { content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,#FFC107,#FF8F00); }
.d1-order-top { display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px; }
.d1-order-id { font-size:.7rem;font-weight:900;color:#9ca3af; }
.d1-order-price { font-size:1.5rem;font-weight:900;color:#22c55e;letter-spacing:-0.5px; }
.d1-step-row { display:flex;align-items:center;gap:0;margin:12px 0; }
.d1-step { display:flex;flex-direction:column;align-items:center;flex:1;position:relative; }
.d1-step:not(:last-child)::after { content:'';position:absolute;top:11px;right:50%;left:-50%;height:2px;background:#e5e7eb; }
.d1-step.done:not(:last-child)::after { background:#22c55e; }
.d1-step.active:not(:last-child)::after { background:linear-gradient(90deg,#FFC107,#e5e7eb); }
.d1-dot { width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.55rem;font-weight:900;position:relative;z-index:1;border:2px solid #e5e7eb;background:#fff; }
.d1-step.done .d1-dot { background:#22c55e;border-color:#22c55e;color:#fff; }
.d1-step.active .d1-dot { background:#FFC107;border-color:#FFC107;color:#111;box-shadow:0 0 10px rgba(255,193,7,0.5); }
.d1-step-lbl { font-size:.52rem;font-weight:800;color:#9ca3af;margin-top:4px;text-align:center; }
.d1-step.active .d1-step-lbl,.d1-step.done .d1-step-lbl { color:#374151; }
.d1-order-actions { display:flex;gap:8px;margin-top:12px; }
.d1-action { flex:1;padding:9px 6px;border-radius:12px;border:none;font-family:'Cairo',sans-serif;font-size:.72rem;font-weight:800;cursor:pointer;text-align:center; }
.d1-a-call { background:#eff6ff;color:#3b82f6; }
.d1-a-map { background:#fff7ed;color:#f97316; }
.d1-a-cta { background:linear-gradient(135deg,#FFC107,#FF8F00);color:#111;flex:2;box-shadow:0 4px 12px rgba(255,193,7,0.25); }

/* ════════════════════════════════════════════════════
   DESIGN 10 — TOYOTA / CORPORATE BOLD
   ════════════════════════════════════════════════════ */
.d10 {
  background: #fff;
  min-height: 100vh;
  font-family: 'Cairo', sans-serif;
}
.d10-hero {
  background: #fff;
  border-bottom: 4px solid #FFC107;
  padding: 0 24px 0;
  position: relative;
}
.d10-hero-inner {
  display: flex; align-items: stretch;
  min-height: 280px;
}
.d10-hero-text {
  flex: 1; padding: 50px 0 30px;
  display: flex; flex-direction: column; justify-content: center;
}
.d10-hero-text .eyebrow {
  font-size: 0.65rem; font-weight: 900; color: #FFC107;
  text-transform: uppercase; letter-spacing: 3px; margin-bottom: 12px;
}
.d10-hero-text h2 { font-size: 2.5rem; font-weight: 900; color: #111; line-height: 1.1; }
.d10-hero-text p { font-size: 0.85rem; color: #6b7280; font-weight: 700; margin-top: 12px; }
.d10-hero-img {
  width: 120px; display: flex; align-items: center; justify-content: center;
  font-size: 6rem; opacity: 0.15;
}
.d10-yellow-band {
  background: #FFC107; padding: 18px 24px;
  display: flex; gap: 24px; overflow-x: auto;
}
.d10-band-stat { text-align: center; min-width: 80px; }
.d10-band-val { font-size: 1.6rem; font-weight: 900; color: #111; }
.d10-band-lbl { font-size: 0.6rem; font-weight: 800; color: rgba(0,0,0,0.6); margin-top: 2px; }
.d10-body { padding: 30px 24px; }
.d10-form-title {
  font-size: 0.7rem; font-weight: 900; color: #9ca3af;
  text-transform: uppercase; letter-spacing: 2px; margin-bottom: 16px;
}
.d10-input {
  width: 100%; border: 2px solid #111;
  border-radius: 0; padding: 14px 16px;
  font-family: 'Cairo', sans-serif; font-size: 1rem; font-weight: 700;
  color: #111; background: #fff; margin-bottom: 14px; outline: none; transition: 0.2s;
}
.d10-input:focus { border-color: #FFC107; background: #FFFDE7; }
.d10-btn {
  display: flex; align-items: center; justify-content: space-between;
  width: 100%; padding: 18px 24px;
  background: #111; color: #FFC107;
  border: none; border-radius: 0;
  font-family: 'Cairo', sans-serif; font-size: 1.05rem; font-weight: 900;
  cursor: pointer; transition: 0.2s;
  border-right: 6px solid #FFC107;
}
.d10-btn:hover { background: #FFC107; color: #111; border-right-color: #111; }

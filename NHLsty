.showcase-info h3 { font-size: 1.05rem; font-weight: 900; color: #111; }
.showcase-info p { font-size: 0.72rem; color: #9ca3af; font-weight: 700; margin-top: 2px; }
.showcase-card {
  border-radius: 28px; overflow: hidden;
  box-shadow: 0 20px 60px rgba(0,0,0,0.13);
  border: 1px solid rgba(0,0,0,0.06);

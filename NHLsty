  margin-top: 30px; width: 100%; max-width: 380px;
}
.d1-stat {
  background: #f9fafb; border-radius: 18px; padding: 20px 12px;
  text-align: center; border: 1px solid #f0f0f0;
}
.d1-stat-val { font-size: 1.6rem; font-weight: 900; color: #FFC107; }
.d1-stat-lbl { font-size: 0.6rem; font-weight: 800; color: #9ca3af; margin-top: 4px; }
.showcase-card::-webkit-scrollbar { width: 3px; }
.showcase-card::-webkit-scrollbar-thumb { background: rgba(255,193,7,0.4); border-radius: 99px; }

/* ════════════════════════════════════════════════════
   DESIGN 2 — UBER / BRUTALIST CLEAN
   ════════════════════════════════════════════════════ */

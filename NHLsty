<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
*,*::before,*::after { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: 'Cairo', sans-serif;
  background: #f0f0f0;
  background: #f0f2f5;
  color: #111;
  min-height: 100vh;
  overflow-x: hidden;
}
/* ─── GALLERY HEADER ─── */
.gallery-header {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  padding: 60px 40px;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%);
  padding: 60px 40px 50px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.gallery-header::before {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse at 50% 0%, rgba(255,193,7,0.2), transparent 70%);
  background: radial-gradient(ellipse at 50% 0%, rgba(255,193,7,0.18), transparent 70%);
}
.gallery-header::after {
  content: '🐝';
  position: absolute; left: -30px; bottom: -40px;
  font-size: 14rem; opacity: 0.04;
}
.gallery-header h1 {
  font-size: 2.8rem;
  font-weight: 900;
  color: #fff;
  position: relative;
  z-index: 1;
  margin-bottom: 8px;
  font-size: 3rem; font-weight: 900; color: #fff;
  position: relative; z-index: 1; margin-bottom: 10px; letter-spacing: -1px;
}
.gallery-header h1 span { color: #FFC107; }
.gallery-header p {
  color: rgba(255,255,255,0.6);
  font-size: 1rem;
  font-weight: 700;
  position: relative;
  z-index: 1;
  color: rgba(255,255,255,0.55); font-size: 1rem;
  font-weight: 700; position: relative; z-index: 1;
}
.gallery-tag {
  display: inline-flex; align-items: center; gap: 8px;
  background: rgba(255,193,7,0.12); border: 1px solid rgba(255,193,7,0.3);
  color: #FFC107; padding: 6px 16px; border-radius: 99px;
  font-size: 0.75rem; font-weight: 900; letter-spacing: 0.5px;
  margin-bottom: 20px; position: relative; z-index: 1;
}
/* ─── DESIGN NAV ─── */
.design-nav {
  display: flex;
  gap: 8px;
  justify-content: center;
  flex-wrap: wrap;
  padding: 24px 20px;
  background: #fff;
  display: flex; gap: 8px; justify-content: center; flex-wrap: wrap;
  padding: 20px 20px; background: #fff;
  border-bottom: 2px solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 1000;
  box-shadow: 0 4px 20px rgba(0,0,0,0.08);
  position: sticky; top: 0; z-index: 1000;
  box-shadow: 0 4px 20px rgba(0,0,0,0.07);
}
.nav-btn {
  padding: 8px 18px;
  border-radius: 99px;
  border: 2px solid #e5e7eb;
  background: #fff;
  font-family: 'Cairo', sans-serif;
  font-weight: 800;
  font-size: 0.78rem;
  cursor: pointer;
  color: #6b7280;
  transition: all 0.2s;
  padding: 8px 18px; border-radius: 99px;
  border: 2px solid #e5e7eb; background: #fff;
  font-family: 'Cairo', sans-serif; font-weight: 800; font-size: 0.78rem;
  cursor: pointer; color: #6b7280; transition: all 0.2s;
}
.nav-btn:hover, .nav-btn.active {
  background: #FFC107;
  border-color: #FFC107;
  color: #111;
}
.nav-btn:hover, .nav-btn.active { background: #FFC107; border-color: #FFC107; color: #111; }

/* ─── SECTION LABEL ─── */
.design-section {
  margin: 0;
  padding: 0;
/* ─── SHOWCASE GRID ─── */
.showcase-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
  gap: 48px; padding: 48px;
  max-width: 1700px; margin: 0 auto;
}
.design-label {
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  color: #FFC107;
  font-size: 0.75rem;
  font-weight: 900;
  letter-spacing: 2px;
  text-transform: uppercase;
  padding: 10px 20px;
  display: flex;
  align-items: center;
  gap: 10px;
.showcase-item {}
.showcase-label {
  display: flex; align-items: center; gap: 14px; margin-bottom: 18px;
}
.design-label span { color: rgba(255,255,255,0.4); }
/* ════════════════════════════════════════════════════
   DESIGN 1 — APPLE / MINIMAL LUXURY
   ════════════════════════════════════════════════════ */
.d1 {
  background: #ffffff;
  min-height: 100vh;
  font-family: 'Cairo', sans-serif;
}
